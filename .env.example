# Public site URL (no trailing slash) — sitemap, robots, canonical SEO
# On Cloudflare Pages: set this to your live URL (e.g. https://www.yourdomain.com)
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Resend (https://resend.com) — contact & quote forms (outbound only)
# Add Resend SPF/DKIM DNS records in Cloudflare for your domain after verifying it in Resend.
RESEND_API_KEY=re_xxxxxxxx

# Where Resend delivers each submission (can be your Gmail, or info@yourdomain if that forwards to Gmail)
CONTACT_EMAIL_TO=you@gmail.com

# Required in production: verify domain in Resend, then use an address on that domain
# CONTACT_EMAIL_FROM=LTY.LTD <quotes@yourdomain.com>

# --- Cloudflare (dashboard / Pages), not .env ---
# - SSL: Universal SSL + SSL/TLS mode Full (strict) for your domain
# - Inbound mail to Gmail: Email Routing → route info@yourdomain → destination Gmail
# - See docs/CLOUDFLARE.md
