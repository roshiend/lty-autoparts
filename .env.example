# Public site URL (no trailing slash) — sitemap, robots, Open Graph.
# Production: set to your canonical HTTPS URL (e.g. https://www.yourdomain.com).
# Cloudflare Pages also sets CF_PAGES_URL during build/preview; prefer NEXT_PUBLIC_SITE_URL for stable SEO.
NEXT_PUBLIC_SITE_URL=https://ltyway.co.uk

# Resend (https://resend.com) — contact & quote forms (outbound only).
# Add Resend SPF/DKIM (and optionally DMARC) in Cloudflare DNS after verifying your domain in Resend.
# Never commit real keys. Paste your key only in Cloudflare Pages env or local .env.local (gitignored).
RESEND_API_KEY=re_xxxxxxxx

# Where Resend delivers each submission. Use your domain address if Cloudflare Email Routing forwards it to your inbox.
# Your setup: info@ltyway.co.uk → lty.housereboot@gmail.com (Email Routing in Cloudflare).
CONTACT_EMAIL_TO=info@ltyway.co.uk

# Required for production builds: verified sender on your domain (not onboarding@resend.dev).
CONTACT_EMAIL_FROM=LTY.LTD <quotes@ltyway.co.uk>

# --- Set in Cloudflare dashboard (Pages → Settings → Variables), not committed ---
# NODE_ENV=production (usually automatic)
# CF_PAGES_URL is injected by Cloudflare Pages when applicable

# --- Cloudflare (dashboard), not .env ---
# - SSL/TLS: Full (strict) once origin serves HTTPS
# - Email Routing: e.g. info@ltyway.co.uk → lty.housereboot@gmail.com (inbound). Forms: Resend → same info@ address.
# - Optional: Web Analytics / Zaraz — configure in Cloudflare dashboard
# - See docs/CLOUDFLARE.md for Workers/OpenNext deploy
